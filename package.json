{
    "name": "cliuno-fastify-template",
    "version": "2.0.1",
    "author": "ru44",
    "license": "AGPL-3.0-only",
    "keywords": [
        "cliuno",
        "fastify",
        "typescript",
        "javascript"
    ],
    "private": true,
    "main": "src/app.ts",
    "scripts": {
        "dev": "nodemon --exec tsx src/app.ts",
        "build": "tsup",
        "start": "node dist/app.js",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix",
        "format": "oxfmt src/",
        "type-check": "tsc --noEmit",
        "prepare": "husky"
    },
    "dependencies": {
        "@fastify/cors": "^11.0.0",
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^13.0.1",
        "dotenv": "^17.4.2",
        "fastify": "^5.10.0",
        "hi-base32": "^0.5.1",
        "jsonwebtoken": "^9.0.3",
        "otpauth": "^9.5.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^1.1.0"
    },
    "devDependencies": {
        "@changesets/cli": "^2.31.1",
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@types/bcrypt": "^6.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^26.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.1",
        "nodemon": "^3.1.14",
        "oxfmt": "^0.60.0",
        "oxlint": "^1.75.0",
        "prettier": "^3.9.6",
        "tsup": "^8.5.1",
        "tsx": "^4.23.1",
        "typescript": "^7.0.2"
    }
}
