{
    "name": "cliuno-fastify-template",
    "version": "2.0.1",
    "author": "ru44",
    "license": "AGPL-3.0-only",
    "keywords": [
        "cliuno",
        "fastify",
        "typescript",
        "javascript"
    ],
    "private": true,
    "main": "src/app.ts",
    "scripts": {
        "dev": "nodemon --exec tsx src/app.ts",
        "build": "tsup",
        "start": "node dist/app.js",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix",
        "format": "oxfmt src/",
        "type-check": "tsc --noEmit",
        "prepare": "husky"
    },
    "dependencies": {
        "@fastify/cors": "^11.0.0",
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^11.10.0",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.0",
        "hi-base32": "^0.5.1",
        "jsonwebtoken": "^9.0.3",
        "otpauth": "^9.5.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@changesets/cli": "^2.27.11",
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@types/bcrypt": "^5.0.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.10.2",
        "husky": "^9.1.7",
        "lint-staged": "^15.2.11",
        "nodemon": "^3.1.9",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "prettier": "^3.5.3",
        "tsup": "^8.3.5",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
}
